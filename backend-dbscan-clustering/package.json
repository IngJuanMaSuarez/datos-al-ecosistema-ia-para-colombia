{
  "name": "clustering-dbscan-backend",
  "version": "1.0.0",
  "description": "Backend de análisis espacial que aplica DBSCAN (Turf.js) sobre puntos recibidos desde el widget de ArcGIS Experience Builder.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "@turf/clusters-dbscan": "^7.1.0",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "rbush": "^4.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/rbush": "^4.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
